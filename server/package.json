{
  "name": "cleanroom-dragonrealms-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test:unit": "tsx scripts/unit-races.ts && tsx scripts/unit-progression.ts && tsx scripts/unit-combat.ts && tsx scripts/unit-economy.ts && tsx scripts/unit-items.ts && tsx scripts/unit-world.ts",
    "smoke:api": "tsx scripts/smoke-api.ts all",
    "smoke:identity": "tsx scripts/smoke-api.ts identity",
    "smoke:races": "tsx scripts/smoke-api.ts races",
    "smoke:guilds": "tsx scripts/smoke-api.ts guilds",
    "smoke:race-guild-matrix": "tsx scripts/smoke-api.ts race-guild-matrix",
    "smoke:scripts": "tsx scripts/smoke-api.ts scripts",
    "smoke:progression": "tsx scripts/smoke-api.ts progression",
    "smoke:economy": "tsx scripts/smoke-api.ts economy",
    "smoke:damaged-ammo": "tsx scripts/smoke-api.ts damaged-ammo",
    "smoke:targets": "tsx scripts/smoke-api.ts targets",
    "smoke:combat": "tsx scripts/smoke-api.ts combat"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.18.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.8.0",
    "@types/ws": "^8.5.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
