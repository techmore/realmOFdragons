{
  "name": "realm-of-dragons-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm --prefix server run build && npm --prefix frontend run build",
    "test:unit": "npm --prefix server run test:unit",
    "smoke:ui": "npm --prefix frontend run smoke:ui",
    "smoke:browser": "npm --prefix frontend run smoke:browser",
    "smoke:api": "npm --prefix server run smoke:api",
    "ci:check": "node scripts/run-checks.mjs ci",
    "agent:check": "node scripts/run-checks.mjs local",
    "agent:prompt": "node scripts/agent-prompt.mjs",
    "agent:next": "node scripts/agent-prompt.mjs"
  }
}
